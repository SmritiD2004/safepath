generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  isAnonymous   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  assessments   Assessment[]
  scenarioRuns  ScenarioRun[]
  tipPractices  UserTipPractice[]
  rolePlaySessions RolePlaySession[]
  certificate   UserCertificate?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Assessment {
  id         String         @id @default(cuid())
  userId     String
  type       AssessmentType
  score      Int
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScenarioRun {
  id               String              @id @default(cuid())
  userId           String?
  scenarioId       String
  status           ScenarioRunStatus   @default(IN_PROGRESS)
  initialRisk      Int
  initialConfidence Int
  initialEq        Int
  finalRisk        Int?
  finalConfidence  Int?
  finalEq          Int?
  startedAt        DateTime            @default(now())
  completedAt      DateTime?
  outcome          String?
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  choiceEvents     ScenarioChoiceEvent[]

  @@index([scenarioId])
  @@index([userId])
  @@index([startedAt])
}

model ScenarioChoiceEvent {
  id                String      @id @default(cuid())
  runId             String
  nodeId            String
  choiceId          String
  choiceText        String
  riskImpact        Int
  eqImpact          Int
  riskBefore        Int
  riskAfter         Int
  confidenceBefore  Int
  confidenceAfter   Int
  eqBefore          Int
  eqAfter           Int
  createdAt         DateTime    @default(now())
  run               ScenarioRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

model UserTipPractice {
  id         String   @id @default(cuid())
  userId     String
  tipId      String
  practiced  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tipId])
  @@index([userId])
}

model RolePlaySession {
  id                String                @id @default(cuid())
  userId            String?
  scenarioId        String
  status            RolePlaySessionStatus @default(IN_PROGRESS)
  initialRisk       Int                   @default(40)
  initialConfidence Int                   @default(50)
  initialEq         Int                   @default(50)
  currentRisk       Int                   @default(40)
  currentConfidence Int                   @default(50)
  currentEq         Int                   @default(50)
  finalRisk         Int?
  finalConfidence   Int?
  finalEq           Int?
  startedAt         DateTime              @default(now())
  completedAt       DateTime?
  outcome           String?
  user              User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages          RolePlayMessage[]

  @@index([userId])
  @@index([scenarioId])
  @@index([startedAt])
}

model RolePlayMessage {
  id               String          @id @default(cuid())
  sessionId        String
  speaker          RolePlaySpeaker
  content          String
  riskImpact       Int             @default(0)
  confidenceImpact Int             @default(0)
  eqImpact         Int             @default(0)
  createdAt        DateTime        @default(now())
  session          RolePlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model UserCertificate {
  id                 String    @id @default(cuid())
  userId             String    @unique
  code               String    @unique
  issuedAt           DateTime  @default(now())
  issuedBy           String    @default("SafePath")
  avgConfidence      Int
  avgEq              Int
  avgRisk            Int
  completedScenarios Int
  totalRuns          Int
  readinessLevel     String

  // ── Admin approval ──────────────────────────────────────────────────────────
  // adminApproved: null = pending, true = approved, false = rejected
  adminApproved      Boolean?
  adminReviewedAt    DateTime?
  adminNote          String?   // optional rejection/approval comment
  // ────────────────────────────────────────────────────────────────────────────

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issuedAt])
  @@index([adminApproved]) // speeds up admin dashboard queries
}

enum UserRole {
  USER
  ADMIN
}

enum AssessmentType {
  PRE
  POST
}

enum ScenarioRunStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum RolePlaySessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum RolePlaySpeaker {
  USER
  NPC
  SYSTEM
}
